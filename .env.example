# Ouvrage environment variables — example file.
#
# Copy this to `.env` and fill in real values. `setup.sh` will generate the
# minimal first-boot version of this file for you (owner email/password) — you
# only need to touch this file directly if you want to customise beyond that
# (Slack notifications, web push, public-URL deployment, etc.).
#
# Leave any line commented to use the default behaviour.

# ── Required: owner account (first boot only) ────────────────────────────────
# These bootstrap the dashboard owner account on first start. After the
# database exists, changing them has no effect — change your password via the
# dashboard instead.
OUVRAGE_OWNER_EMAIL=you@example.com
OUVRAGE_OWNER_PASSWORD=change-me

# Optional: pass a pre-hashed Argon2id password instead of plaintext.
# OUVRAGE_OWNER_PASSWORD_HASH=

# Optional: friendly name shown in dashboard chrome.
# OUVRAGE_OWNER_NAME=Owner
# OUVRAGE_INSTANCE_NAME=Ouvrage
# OUVRAGE_INSTANCE_SLUG=default

# ── Optional: semantic search ────────────────────────────────────────────────
# Without this, conversation search falls back to FTS5 only (no vectors).
# OPENAI_API_KEY=sk-...

# ── Optional: Slack notifications ────────────────────────────────────────────
# Posts task lifecycle events (dispatch / progress / completion / failure) to a
# threaded message in the configured channel. Both must be set together.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0...

# ── Optional: browser push notifications ─────────────────────────────────────
# Generate with: docker compose run --rm --entrypoint "" ouvrage \
#   python3 -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); \
#               print(v.private_key.private_bytes_raw().hex(), \
#                     v.public_key.public_bytes_raw().hex())"
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_CLAIM_EMAIL=mailto:you@example.com

# ── Optional: public deployment ──────────────────────────────────────────────
# Override only if running behind a reverse proxy on a public hostname.
# OAUTH_BASE_URL=https://ouvrage.example.com
# AUTH_ISSUER_URL=https://ouvrage.example.com
# RESOURCE_URL=https://ouvrage.example.com/mcp
# AUTH_MODE=local

# ── Optional: tuning knobs ───────────────────────────────────────────────────
# OUVRAGE_PORT=8100
# MAX_PROJECTS=50
# RECOVERY_ENABLED=true
# RECOVERY_STAGGER_SECONDS=2
# MAX_RECOVERY_ATTEMPTS=3
# SKIP_CREDENTIAL_CHECK=false

# ── Secrets handled outside .env (don't put here) ────────────────────────────
# OUVRAGE_MASTER_KEY     → Docker secret at ./secrets/master_key
# OPENAI_API_KEY (alt)   → Docker secret at ./secrets/openai_key
# OAuth RSA private key  → auto-generated at /data/oauth_rsa_key.pem
