# Ouvrage environment variables — copy to .env (or /etc/ouvrage/env for systemd).
# Only OUVRAGE_MASTER_KEY is strictly required on first boot; everything else
# has sensible defaults or is feature-gated.

# ── Required ────────────────────────────────────────────────────────────────
# Fernet key used to encrypt stored credentials (GitHub PATs, Anthropic keys,
# OAuth client secrets). Generate once with:
#   python3 -m ouvrage generate-key
# Keep this stable across restarts. If you lose it, previously-encrypted data
# is permanently unrecoverable.
OUVRAGE_MASTER_KEY=

# ── Core paths ──────────────────────────────────────────────────────────────
# SQLite database file. Defaults to ./data/ouvrage.db outside a container.
OUVRAGE_DB=/data/ouvrage.db
# OAuth RSA private key (auto-generated on first boot if missing).
OAUTH_RSA_KEY_PATH=/data/oauth_rsa_key.pem
# HTTP port the MCP server listens on.
PORT=8100

# ── First-run owner bootstrap ───────────────────────────────────────────────
# If these are set on first boot, the owner user is created automatically.
# Generate the hash with:
#   python3 -m ouvrage hash-password
# OUVRAGE_OWNER_EMAIL=admin@example.com
# OUVRAGE_OWNER_NAME=Admin
# OUVRAGE_OWNER_PASSWORD_HASH=$argon2id$...

# ── Worker isolation (production only) ──────────────────────────────────────
# Name of the OS user CC workers run as via setuid. Must exist on the host.
# When unset or missing, _run_as_worker falls back to the current process user
# (dev/CI/OSS without privilege separation).
WORKER_USER=switchboard

# ── Auth mode ───────────────────────────────────────────────────────────────
# "local" — built-in login page + self-issued OAuth (default)
# "saas"  — SSO redirect to a control plane; requires CONTROL_PLANE_* below
AUTH_MODE=local

# OAuth issuer / audience / resource URL (for OAuth JWTs issued by the built-in server).
# OAUTH_BASE_URL=https://ouvrage.example.dev
# AUTH_ISSUER_URL=https://ouvrage.example.dev
# AUTH_AUDIENCE=https://ouvrage.example.dev/mcp
# RESOURCE_URL=https://ouvrage.example.dev/mcp

# ── SaaS mode (leave unset for standalone) ──────────────────────────────────
# CONTROL_PLANE_URL=https://control.example.dev
# CONTROL_PLANE_JWKS=https://control.example.dev/api/auth/.well-known/jwks.json
# INSTANCE_SLUG=default
# INTERNAL_API_TOKEN=

# ── Optional integrations ───────────────────────────────────────────────────
# Semantic search / embedding:
# OPENAI_API_KEY=

# Slack notifications (per-task threads):
# SLACK_BOT_TOKEN=xoxb-your-token-here
# SLACK_CHANNEL_ID=C0YOUR_CHANNEL

# Web push (VAPID):
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_CLAIM_EMAIL=mailto:admin@example.com

# ── Quotas / limits ─────────────────────────────────────────────────────────
# Maximum concurrent CC worker sessions (0 = no limit beyond instance config).
# CONCURRENCY_LIMIT=6
# Maximum number of registered projects (0 = unlimited).
MAX_PROJECTS=0

# ── Dev / testing ───────────────────────────────────────────────────────────
# Skip the dispatch-time credential pre-flight check. Useful for dev without
# a real Anthropic API key.
# SKIP_CREDENTIAL_CHECK=false
